DATABASE_URL="file:./dev.db"
ADMIN_PASSWORD_HASH="<bcrypt-hash-of-your-password>"
COOKIE_SECRET="<at-least-32-random-characters>"
CONTACT_EMAIL="hello@example.com"
ICP_DOMAIN_1="example.cn"
ICP_NUMBER_1="晋ICP备XXXXXXXX号-1"
ICP_DOMAIN_2="example.com"
ICP_NUMBER_2="晋ICP备XXXXXXXX号-2"

# Qiniu Cloud (七牛云) - Image upload
QINIU_ACCESS_KEY="<your-access-key>"
QINIU_SECRET_KEY="<your-secret-key>"
QINIU_BUCKET="<your-bucket-name>"
QINIU_CDN_DOMAIN="https://your-cdn-domain.com"  # 预览 URL 前缀，绑定在 bucket 上的加速域名
QINIU_UPLOAD_URL="https://up.qiniup.com"
# 上传地址，按存储区域选择：
#   华东一区: https://up.qiniup.com
#   华北一区: https://up-z1.qiniup.com
#   华南一区: https://up-z2.qiniup.com
#   北美一区: https://up-na0.qiniup.com
